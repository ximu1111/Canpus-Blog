/* pages/detail/detail.wxss */

.blog-detail {
  margin-top: 20rpx;
}

/* 作者信息 */
.author-section {
  margin-bottom: 24rpx;
}

.author-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.author-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  display: block;
}

.author-school {
  font-size: 24rpx;
  display: block;
  margin-top: 4rpx;
}

.publish-time {
  font-size: 22rpx;
  margin-top: 4rpx;
}

.follow-btn {
  padding: 8rpx 28rpx;
  border-radius: var(--radius-button);
  background-color: var(--color-primary);
  color: #FFFFFF;
  font-size: 24rpx;
  text-align: center;
}

.follow-btn.followed {
  background-color: var(--color-bg);
  color: var(--color-text-secondary);
  border: 1rpx solid var(--color-border);
}

/* 内容区 */
.content-section {
  margin-bottom: 24rpx;
}

.blog-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: var(--color-text);
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.tag-row {
  margin-bottom: 20rpx;
}

.blog-body {
  font-size: 30rpx;
  color: var(--color-text);
  line-height: 1.8;
  display: block;
}

/* 图片 */
.image-section {
  margin-bottom: 24rpx;
}

.image-grid-single .detail-image {
  width: 100%;
  border-radius: 12rpx;
  max-height: 600rpx;
}

.image-grid-multi {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.image-grid-multi .detail-image {
  width: calc(50% - 6rpx);
  border-radius: 12rpx;
}

/* 数据统计 */
.stats-section {
  padding-top: 24rpx;
  border-top: 1rpx solid var(--color-border);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text);
}

.stat-label {
  font-size: 22rpx;
  margin-top: 4rpx;
}

/* 评论区 */
.comment-section {
  margin-bottom: 140rpx;
}

.section-header {
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
}

.sort-btn {
  padding: 8rpx 16rpx;
}

.loading-wrap {
  padding: 40rpx 0;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background-color: var(--color-card);
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  z-index: 200;
  gap: 16rpx;
}

.bar-left {
  flex: 1;
}

.input-wrap {
  background-color: var(--color-bg);
  border-radius: var(--radius-button);
  padding: 16rpx 28rpx;
}

.input-placeholder {
  font-size: 26rpx;
  color: var(--color-text-light);
}

.bar-right {
  gap: 28rpx;
}

.bar-action {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
}

.bar-icon {
  font-size: 36rpx;
  transition: transform 0.2s ease;
}

.bar-icon.active {
  animation: likeScale 0.3s ease-in-out;
}

.bar-count {
  font-size: 20rpx;
  color: var(--color-text-secondary);
}

/* 评论输入弹窗 */
.comment-input-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 300;
  display: flex;
  align-items: flex-end;
}

.comment-input-panel {
  width: 100%;
  background-color: var(--color-card);
  border-radius: 24rpx 24rpx 0 0;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.input-header {
  margin-bottom: 20rpx;
}

.input-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
}

.input-close {
  font-size: 32rpx;
  color: var(--color-text-secondary);
  padding: 8rpx;
}

.input-body {
  margin-bottom: 20rpx;
}

.comment-textarea {
  width: 100%;
  min-height: 160rpx;
  background-color: var(--color-bg);
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

.input-footer {
  margin-top: 16rpx;
}

.char-count {
  font-size: 24rpx;
}

.send-btn {
  padding: 12rpx 40rpx;
  font-size: 28rpx;
}
