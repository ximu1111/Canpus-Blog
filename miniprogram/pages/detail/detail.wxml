<!-- pages/detail/detail.wxml - 博客详情页 -->
<view class="page-container">
  <!-- 博客内容 -->
  <view class="blog-detail card" wx:if="{{blog}}">
    <!-- 作者信息 -->
    <view class="author-section flex-row">
      <image
        class="avatar avatar-md"
        src="{{blog.user.avatarUrl}}"
        mode="aspectFill"
        bind:tap="onUserTap"
      />
      <view class="author-info flex-1" style="margin-left: 20rpx;">
        <view class="flex-between">
          <view>
            <text class="author-name">{{blog.user.nickName}}</text>
            <text class="author-school text-secondary">{{blog.user.school}} · {{blog.user.major}}</text>
          </view>
          <view
            wx:if="{{!isSelf}}"
            class="follow-btn {{blog.user.isFollowed ? 'followed' : ''}}"
            bind:tap="onFollowTap"
          >
            <text>{{blog.user.isFollowed ? '已关注' : '+ 关注'}}</text>
          </view>
        </view>
        <text class="publish-time text-secondary">{{blog.timeFormatted}}</text>
      </view>
    </view>

    <!-- 标题和内容 -->
    <view class="content-section">
      <text class="blog-title">{{blog.title}}</text>
      <view class="tag-row">
        <view class="tag tag-primary">{{blog.categoryName}}</view>
      </view>
      <text class="blog-body">{{blog.content}}</text>
    </view>

    <!-- 图片展示 -->
    <view wx:if="{{blog.images.length > 0}}" class="image-section">
      <view class="image-grid-{{blog.images.length === 1 ? 'single' : 'multi'}}">
        <image
          wx:for="{{blog.images}}"
          wx:key="index"
          class="detail-image"
          src="{{item}}"
          mode="widthFix"
          lazy-load
          bind:tap="onImagePreview"
          data-url="{{item}}"
        />
      </view>
    </view>

    <!-- 数据统计 -->
    <view class="stats-section flex-between">
      <view class="stat-item">
        <text class="stat-value">{{blog.viewCount}}</text>
        <text class="stat-label text-secondary">阅读</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{blog.likeCount}}</text>
        <text class="stat-label text-secondary">点赞</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{blog.commentCount}}</text>
        <text class="stat-label text-secondary">评论</text>
      </view>
    </view>
  </view>

  <!-- 评论区 -->
  <view class="comment-section card">
    <view class="section-header flex-between">
      <text class="section-title">评论 ({{comments.length}})</text>
      <view class="sort-btn text-secondary" bind:tap="onSortChange">
        <text style="font-size: 24rpx;">{{sortType === 'latest' ? '最新' : '最热'}}</text>
      </view>
    </view>

    <view wx:if="{{comments.length > 0}}" class="comment-list">
      <comment-item
        wx:for="{{comments}}"
        wx:key="id"
        comment="{{item}}"
        bind:reply="onCommentReply"
        bind:commentlike="onCommentLike"
        bind:usertap="onUserTap"
      />
    </view>

    <van-empty
      wx:if="{{!commentLoading && comments.length === 0}}"
      description="暂无评论，快来抢沙发~"
      image="comment"
    />

    <view wx:if="{{commentLoading}}" class="loading-wrap flex-center">
      <van-loading size="20px" color="#4F86C6">加载中...</van-loading>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar">
    <view class="bar-left flex-1">
      <view class="input-wrap" bind:tap="onCommentInputTap">
        <text class="input-placeholder">写评论...</text>
      </view>
    </view>
    <view class="bar-right flex-row">
      <view class="bar-action" bind:tap="onLikeTap">
        <text class="bar-icon {{blog.isLiked ? 'active' : ''}}">
          {{blog.isLiked ? '❤️' : '🤍'}}
        </text>
        <text class="bar-count">{{blog.likeCount || 0}}</text>
      </view>
      <view class="bar-action" bind:tap="onCollectTap">
        <text class="bar-icon {{blog.isCollected ? 'active' : ''}}">
          {{blog.isCollected ? '⭐' : '☆'}}
        </text>
      </view>
      <view class="bar-action" bind:tap="onShareTap">
        <text class="bar-icon">📤</text>
      </view>
    </view>
  </view>

  <!-- 评论输入弹窗 -->
  <view wx:if="{{showCommentInput}}" class="comment-input-mask" bind:tap="onCloseCommentInput">
    <view class="comment-input-panel" catch:tap="">
      <view class="input-header flex-between">
        <text class="input-title">{{replyToUser ? '回复 ' + replyToUser.nickName : '写评论'}}</text>
        <text class="input-close" bind:tap="onCloseCommentInput">✕</text>
      </view>
      <view class="input-body flex-row">
        <textarea
          class="comment-textarea"
          placeholder="{{replyToUser ? '回复 ' + replyToUser.nickName + '...' : '写下你的评论...'}}"
          value="{{commentText}}"
          bindinput="onCommentTextChange"
          focus="{{showCommentInput}}"
          maxlength="500"
          auto-height
          show-confirm-bar="{{false}}"
        />
      </view>
      <view class="input-footer flex-between">
        <text class="char-count text-secondary">{{commentText.length}}/500</text>
        <button
          class="btn-primary send-btn {{commentText.trim() ? '' : 'btn-disabled'}}"
          bind:tap="onSendComment"
        >发送</button>
      </view>
    </view>
  </view>
</view>
