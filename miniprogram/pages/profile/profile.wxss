/* pages/profile/profile.wxss */

/* 头部 */
.profile-header {
  position: relative;
  padding-bottom: 24rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 280rpx;
  background-color: var(--color-primary);
}

.user-section {
  position: relative;
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 60rpx 32rpx 32rpx;
}

.user-detail {
  flex: 1;
  min-width: 0;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #FFFFFF;
  display: block;
}

.user-bio {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
  margin-top: 8rpx;
}

.user-tags {
  margin-top: 12rpx;
  gap: 12rpx;
}

.user-tags .tag {
  background-color: rgba(255, 255, 255, 0.2);
  color: #FFFFFF;
  font-size: 22rpx;
}

/* 登录提示 */
.login-prompt {
  gap: 20rpx;
  padding: 40rpx 0;
}

.login-text-wrap {
  display: flex;
  flex-direction: column;
}

.login-text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-primary);
}

.login-sub {
  font-size: 24rpx;
  margin-top: 4rpx;
}

/* 数据统计 */
.stats-row {
  position: relative;
  background-color: var(--color-card);
  margin: 0 24rpx;
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
  padding: 28rpx 0;
}

.stat-block {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.stat-num {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--color-text);
}

.stat-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background-color: var(--color-border);
}

/* 通用 section */
.section {
  margin-top: 20rpx;
}

.section-header {
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
}

.section-more {
  font-size: 24rpx;
}

/* 我的博客列表 */
.my-blog-list {
  display: flex;
  flex-direction: column;
}

.my-blog-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.my-blog-item:last-child {
  border-bottom: none;
}

.my-blog-title {
  font-size: 28rpx;
  color: var(--color-text);
  display: block;
  margin-bottom: 8rpx;
}

.my-blog-meta {
  gap: 8rpx;
  font-size: 22rpx;
}

.empty-hint {
  padding: 40rpx 0;
}

/* 菜单 */
.menu-section {
  padding: 8rpx var(--spacing-inner);
}

.menu-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  gap: 16rpx;
}

.menu-icon {
  font-size: 36rpx;
}

.menu-name {
  font-size: 28rpx;
  color: var(--color-text);
}

.menu-arrow {
  font-size: 32rpx;
}

/* 退出登录 */
.logout-section {
  padding: 40rpx 24rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 30rpx;
  color: var(--color-danger);
  background-color: var(--color-card);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
  border: none;
}

.logout-btn::after {
  border: none;
}
