/* pages/publish/publish.wxss */

.publish-section {
  margin-top: 20rpx;
}

.section-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 16rpx;
}

.section-tip {
  font-size: 22rpx;
  font-weight: normal;
}

/* 标题输入 */
.title-input {
  width: 100%;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--color-border);
  box-sizing: border-box;
}

.input-placeholder {
  color: var(--color-text-light);
  font-size: 28rpx;
}

.char-count {
  text-align: right;
  font-size: 22rpx;
  margin-top: 8rpx;
}

/* 分类选择 */
.category-select {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
}

.category-placeholder {
  color: var(--color-text-light);
  font-size: 28rpx;
}

.arrow-icon {
  font-size: 36rpx;
  color: var(--color-text-secondary);
}

/* 内容编辑 */
.toolbar-inline {
  gap: 8rpx;
}

.tool-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  background-color: var(--color-bg);
}

.tool-btn-hover {
  background-color: var(--color-border);
}

.tool-icon {
  font-size: 26rpx;
}

.content-textarea {
  width: 100%;
  min-height: 300rpx;
  font-size: 28rpx;
  color: var(--color-text);
  line-height: 1.8;
  padding: 16rpx 0;
  box-sizing: border-box;
}

/* 图片上传 */
.image-upload-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.upload-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.upload-preview {
  width: 100%;
  height: 100%;
}

.upload-delete {
  position: absolute;
  top: 0;
  right: 0;
  width: 44rpx;
  height: 44rpx;
  background-color: rgba(0, 0, 0, 0.5);
  border-radius: 0 0 0 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  color: #FFFFFF;
  font-size: 22rpx;
}

.compress-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.4);
}

.compress-text {
  color: #FFFFFF;
  font-size: 22rpx;
}

.upload-add {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed var(--color-border);
  border-radius: 12rpx;
  flex-direction: column;
  gap: 8rpx;
}

.add-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background-color: var(--color-primary-light);
}

.add-icon {
  font-size: 40rpx;
  color: var(--color-primary);
  font-weight: 300;
}

.add-text {
  font-size: 22rpx;
}

/* 操作按钮 */
.action-section {
  display: flex;
  gap: 24rpx;
  padding: 40rpx 24rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.btn-preview {
  flex: 1;
}

.btn-publish {
  flex: 2;
}

/* 分类选择弹窗 */
.picker-header {
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.picker-cancel {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.picker-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
}

.picker-confirm {
  font-size: 28rpx;
  color: var(--color-primary);
  font-weight: 500;
}

.picker-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 24rpx;
  gap: 16rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.picker-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 32rpx;
  border-radius: var(--radius-button);
  background-color: var(--color-bg);
  transition: all 0.2s ease;
}

.picker-item.active {
  background-color: var(--color-primary);
  color: #FFFFFF;
}

.picker-icon {
  font-size: 32rpx;
}

.picker-name {
  font-size: 28rpx;
}

/* 预览弹窗 */
.preview-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.preview-header {
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--color-border);
  flex-shrink: 0;
}

.preview-title-text {
  font-size: 32rpx;
  font-weight: 600;
}

.preview-close {
  font-size: 36rpx;
  color: var(--color-text-secondary);
  padding: 8rpx;
}

.preview-scroll {
  flex: 1;
  padding: 20rpx;
}

.preview-content {
  margin: 0;
}

.preview-user {
  margin-bottom: 24rpx;
}

.preview-user-name {
  font-size: 28rpx;
  font-weight: 600;
  display: block;
}

.preview-user-school {
  font-size: 22rpx;
  display: block;
  margin-top: 4rpx;
}

.preview-blog-title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--color-text);
  line-height: 1.5;
  display: block;
  margin-bottom: 16rpx;
}

.preview-blog-content {
  font-size: 30rpx;
  color: var(--color-text);
  line-height: 1.8;
  display: block;
  margin-bottom: 20rpx;
}

.preview-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.preview-image {
  width: calc(33.33% - 8rpx);
  height: 200rpx;
  border-radius: 8rpx;
}
