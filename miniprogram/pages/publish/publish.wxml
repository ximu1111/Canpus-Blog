<!-- pages/publish/publish.wxml - 发布页 -->
<view class="page-container">
  <!-- 标题输入 -->
  <view class="publish-section card">
    <view class="section-label">标题</view>
    <input
      class="title-input"
      placeholder="给博客取个标题吧"
      placeholder-class="input-placeholder"
      value="{{title}}"
      bindinput="onTitleInput"
      maxlength="50"
    />
    <view class="char-count text-secondary">{{title.length}}/50</view>
  </view>

  <!-- 分类选择 -->
  <view class="publish-section card">
    <view class="section-label">分类</view>
    <view class="category-select" bind:tap="onCategorySelect">
      <view wx:if="{{selectedCategory}}" class="selected-tag tag tag-primary">
        {{selectedCategory.icon}} {{selectedCategory.name}}
      </view>
      <text wx:else class="category-placeholder">选择分类</text>
      <text class="arrow-icon">›</text>
    </view>
  </view>

  <!-- 内容编辑 -->
  <view class="publish-section card">
    <view class="section-label flex-between">
      <text>内容</text>
      <view class="toolbar-inline flex-row">
        <view class="tool-btn" bind:tap="onInsertBold" hover-class="tool-btn-hover">
          <text class="tool-icon">B</text>
        </view>
        <view class="tool-btn" bind:tap="onInsertEmoji" hover-class="tool-btn-hover">
          <text class="tool-icon">😊</text>
        </view>
        <view class="tool-btn" bind:tap="onInsertLink" hover-class="tool-btn-hover">
          <text class="tool-icon">🔗</text>
        </view>
      </view>
    </view>
    <textarea
      class="content-textarea"
      placeholder="分享你的故事、经验或想法..."
      placeholder-class="input-placeholder"
      value="{{content}}"
      bindinput="onContentInput"
      maxlength="5000"
      auto-height
      show-confirm-bar="{{false}}"
    />
    <view class="char-count text-secondary">{{content.length}}/5000</view>
  </view>

  <!-- 图片上传 -->
  <view class="publish-section card">
    <view class="section-label flex-between">
      <text>图片 ({{imageList.length}}/9)</text>
      <text class="section-tip text-secondary">支持压缩预览</text>
    </view>
    <view class="image-upload-grid">
      <!-- 已选图片 -->
      <view
        wx:for="{{imageList}}"
        wx:key="index"
        class="upload-item"
      >
        <image
          class="upload-preview"
          src="{{item.url}}"
          mode="aspectFill"
          bind:tap="onImagePreview"
          data-index="{{index}}"
        />
        <view class="upload-delete" catch:tap="onImageDelete" data-index="{{index}}">
          <text class="delete-icon">✕</text>
        </view>
        <view wx:if="{{item.compressing}}" class="compress-mask flex-center">
          <text class="compress-text">压缩中...</text>
        </view>
      </view>

      <!-- 添加按钮 -->
      <view
        wx:if="{{imageList.length < 9}}"
        class="upload-add flex-center"
        bind:tap="onChooseImage"
      >
        <view class="add-icon-wrap flex-center">
          <text class="add-icon">+</text>
        </view>
        <text class="add-text text-secondary">添加图片</text>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-section">
    <button class="btn-preview btn-outline" bind:tap="onPreview">
      预览
    </button>
    <button class="btn-publish btn-primary {{canPublish ? '' : 'btn-disabled'}}" bind:tap="onPublish">
      发布博客
    </button>
  </view>

  <!-- 分类选择弹窗 -->
  <van-popup
    show="{{showCategoryPicker}}"
    position="bottom"
    round
    bind:close="onCloseCategoryPicker"
  >
    <view class="picker-header flex-between">
      <text class="picker-cancel" bind:tap="onCloseCategoryPicker">取消</text>
      <text class="picker-title">选择分类</text>
      <text class="picker-confirm" bind:tap="onConfirmCategory">确认</text>
    </view>
    <view class="picker-grid">
      <view
        wx:for="{{categories}}"
        wx:key="id"
        class="picker-item {{tempCategory && tempCategory.id === item.id ? 'active' : ''}}"
        bind:tap="onPickerItemTap"
        data-index="{{index}}"
      >
        <text class="picker-icon">{{item.icon}}</text>
        <text class="picker-name">{{item.name}}</text>
      </view>
    </view>
  </van-popup>

  <!-- 预览弹窗 -->
  <van-popup
    show="{{showPreview}}"
    position="bottom"
    round
    full
    bind:close="onClosePreview"
  >
    <view class="preview-container">
      <view class="preview-header flex-between">
        <text class="preview-title-text">预览</text>
        <text class="preview-close" bind:tap="onClosePreview">✕</text>
      </view>
      <scroll-view scroll-y class="preview-scroll">
        <view class="preview-content card">
          <view class="preview-user flex-row">
            <image class="avatar avatar-sm" src="{{userAvatar}}" mode="aspectFill" />
            <view style="margin-left: 16rpx;">
              <text class="preview-user-name">{{userName}}</text>
              <text class="preview-user-school text-secondary">{{userSchool}}</text>
            </view>
          </view>
          <text class="preview-blog-title">{{title}}</text>
          <view wx:if="{{selectedCategory}}" class="tag tag-primary" style="margin-bottom: 16rpx; display: inline-flex;">
            {{selectedCategory.icon}} {{selectedCategory.name}}
          </view>
          <text class="preview-blog-content">{{content}}</text>
          <view wx:if="{{imageList.length > 0}}" class="preview-images">
            <image
              wx:for="{{imageList}}"
              wx:key="index"
              class="preview-image"
              src="{{item.url}}"
              mode="aspectFill"
            />
          </view>
        </view>
      </scroll-view>
    </view>
  </van-popup>

  <van-toast id="van-toast" />
</view>
