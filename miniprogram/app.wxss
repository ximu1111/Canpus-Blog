/* app.wxss - 全局样式 */

/* ========== CSS 变量定义 ========== */
page {
  --color-primary: #4F86C6;
  --color-primary-light: #E8F0FE;
  --color-primary-dark: #3A6BA5;
  --color-accent: #FF8C42;
  --color-accent-light: #FFF3EB;
  --color-bg: #F5F7FA;
  --color-card: #FFFFFF;
  --color-text: #2C3E50;
  --color-text-secondary: #8E99A4;
  --color-text-light: #B0B8C1;
  --color-border: #EBEEF2;
  --color-danger: #E74C3C;
  --color-success: #27AE60;

  --font-size-title: 32rpx;
  --font-size-body: 28rpx;
  --font-size-caption: 24rpx;
  --font-size-small: 22rpx;

  --spacing-page: 24rpx;
  --spacing-card: 20rpx;
  --spacing-inner: 24rpx;
  --spacing-element: 16rpx;

  --radius-card: 16rpx;
  --radius-button: 40rpx;
  --radius-tag: 8rpx;

  --shadow-card: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  --shadow-float: 0 4rpx 20rpx rgba(79, 134, 198, 0.3);

  background-color: var(--color-bg);
  color: var(--color-text);
  font-size: var(--font-size-body);
  line-height: 1.6;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica,
    'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', Arial, sans-serif;
}

/* ========== 通用工具类 ========== */
.page-container {
  min-height: 100vh;
  background-color: var(--color-bg);
  padding-bottom: env(safe-area-inset-bottom);
}

.card {
  background-color: var(--color-card);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
  margin: var(--spacing-card) var(--spacing-page);
  padding: var(--spacing-inner);
}

.text-primary {
  color: var(--color-primary);
}

.text-secondary {
  color: var(--color-text-secondary);
}

.text-accent {
  color: var(--color-accent);
}

.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.text-ellipsis-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

.flex-1 {
  flex: 1;
}

/* ========== 头像样式 ========== */
.avatar {
  border-radius: 50%;
  overflow: hidden;
  background-color: var(--color-border);
}

.avatar-sm {
  width: 56rpx;
  height: 56rpx;
}

.avatar-md {
  width: 80rpx;
  height: 80rpx;
}

.avatar-lg {
  width: 120rpx;
  height: 120rpx;
}

/* ========== 按钮样式 ========== */
.btn-primary {
  background-color: var(--color-primary);
  color: #FFFFFF;
  border: none;
  border-radius: var(--radius-button);
  padding: 16rpx 48rpx;
  font-size: var(--font-size-body);
  text-align: center;
  line-height: 1.5;
}

.btn-primary::after {
  border: none;
}

.btn-outline {
  background-color: transparent;
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
  border-radius: var(--radius-button);
  padding: 14rpx 48rpx;
  font-size: var(--font-size-body);
  text-align: center;
  line-height: 1.5;
}

.btn-outline::after {
  border: none;
}

.btn-disabled {
  opacity: 0.5;
  pointer-events: none;
}

/* ========== 标签样式 ========== */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-tag);
  font-size: var(--font-size-small);
  line-height: 1.6;
}

.tag-primary {
  background-color: var(--color-primary-light);
  color: var(--color-primary);
}

.tag-accent {
  background-color: var(--color-accent-light);
  color: var(--color-accent);
}

/* ========== 分割线 ========== */
.divider {
  height: 1rpx;
  background-color: var(--color-border);
  margin: var(--spacing-element) 0;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-state .empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
  opacity: 0.4;
}

.empty-state .empty-text {
  font-size: var(--font-size-caption);
  color: var(--color-text-secondary);
}

/* ========== 动画 ========== */
@keyframes likeScale {
  0% { transform: scale(1); }
  50% { transform: scale(1.3); }
  100% { transform: scale(1); }
}

.animate-like {
  animation: likeScale 0.3s ease-in-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.animate-fade-in {
  animation: fadeIn 0.3s ease-out;
}
